# ---------------------------------------------------------------------------
# Supabase project settings — from Project Settings > API in the Supabase
# dashboard. NEXT_PUBLIC_* values are safe to expose to the browser.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY. Used for admin actions (inviting users).
# Never expose this to the browser or commit it to source control.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL of the deployed app, used to build invite/reset links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
